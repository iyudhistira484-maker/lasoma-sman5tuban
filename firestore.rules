rules_version = '2';

// Firestore rules untuk Lasoma SMAN 5 Tuban
// Collection: comments  -> { name: string, message: string, createdAt: timestamp }
//
// Policy:
// - Siapa saja boleh BACA komentar (publik).
// - Siapa saja boleh KIRIM komentar (create), tapi divalidasi:
//     * field hanya: name, message, createdAt
//     * name 2-60 char, message 3-1000 char
//     * createdAt = serverTimestamp()
// - Siapa saja boleh HAPUS komentar (delete) — pakai konfirmasi di UI.
//   Catatan: kalau mau dibatasi admin saja, ganti `allow delete: if true;`
//   menjadi `allow delete: if false;` dan hapus lewat Firebase Console.
// - Update tetap dilarang dari client.

service cloud.firestore {
  match /databases/{database}/documents {

    match /comments/{commentId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(['name', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 60
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 3
        && request.resource.data.message.size() <= 1000
        && request.resource.data.createdAt == request.time;

      allow delete: if true;
      allow update: if false;
    }

    // Tutup koleksi lain secara default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
